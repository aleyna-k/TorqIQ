@page "/Machines/{machineId:int}/Maintenance/Create"
@model TorqIQ.Pages.Machines.Maintenance.CreateModel
@{ ViewData["Title"] = "Add Maintenance Record"; ViewData["MachineId"] = Model.MachineId; }

<div class="card">
  <div class="header-bar">
    <div>
      <div class="machine-title">Add Maintenance Record</div>
      <div class="machine-sub">@Model.MachineName</div>
    </div>
    <div class="btn-row">
      <a class="btn" href="/Machines/Details/@Model.MachineId?tab=maint">Cancel</a>
    </div>
  </div>

  <form method="post">
    @Html.AntiForgeryToken()
    <div class="field-grid">
      <div class="field">
        <label>Date</label>
        <input asp-for="Record.Date" placeholder="e.g. 15 Jan 2024" />
      </div>
      <div class="field">
        <label>Performed By</label>
        <input asp-for="Record.PerformedBy" placeholder="Technician name" />
      </div>
      <div class="field full">
        <label>Work Done / Parts Replaced</label>
        <textarea asp-for="Record.WorkDone" rows="3" placeholder="Describe the work performed…"></textarea>
      </div>
      <div class="field">
        <label>Result</label>
        <select asp-for="Record.Result">
          <option>OK</option>
          <option>Pending</option>
          <option>Failed</option>
        </select>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn primary">Save Record</button>
    </div>
  </form>
</div>
