@page
@model TorqIQ.Pages.Machines.CreateModel
@{ ViewData["Title"] = "New Machine"; }

<div class="card">
  <div class="header-bar">
    <div>
      <div class="machine-title">New Machine</div>
      <div class="machine-sub">Fill in the details below and save</div>
    </div>
    <div class="btn-row">
      <a class="btn" href="/">Cancel</a>
    </div>
  </div>

  <form method="post">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("_MachineForm", Model.Machine)
    <div class="form-actions">
      <button type="submit" class="btn primary">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Save Machine
      </button>
    </div>
  </form>
</div>
