@page "/Machines/Details/{id:int}"
@model TorqIQ.Pages.Machines.DetailsModel
@{
    ViewData["Title"] = Model.Machine.Name;
    ViewData["MachineId"] = Model.Machine.Id;
    var m = Model.Machine;
    var tab = Model.ActiveTab;
}

<div class="card">
  <div class="header-bar">
    <div>
      <div class="machine-title">
        <span class="code-badge">@(string.IsNullOrEmpty(m.Code) ? "—" : m.Code)</span>
        @m.Name
      </div>
      <div class="machine-sub">
        <span>@(m.Brand ?? "No brand")</span>
        <span class="sep">·</span>
        <span>@m.Period</span>
        <span class="sep">·</span>
        <span>@m.Energy</span>
        <span class="sep">·</span>
        <span>@m.MaintenanceRecords.Count maintenance records</span>
        <span class="sep">·</span>
        <span>@m.FailureRecords.Count failure records</span>
      </div>
    </div>
    <div class="btn-row">
      <a class="btn primary" href="/Machines/Edit/@m.Id">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Edit
      </a>
      <button class="btn" onclick="window.print()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 6 2 18 2 18 9"/>
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
          <rect x="6" y="14" width="12" height="8"/>
        </svg>
        Print
      </button>
      <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Delete this machine? This cannot be undone.')">
        <input type="hidden" asp-for="Machine.Id" />
        <button type="submit" class="btn danger">Delete</button>
      </form>
    </div>
  </div>

  <!-- TABS -->
  <div class="tab-bar">
    <a class="tab @(tab == "info"  ? "active" : "")" href="?tab=info">Overview</a>
    <a class="tab @(tab == "maint" ? "active" : "")" href="?tab=maint">Maintenance (@m.MaintenanceRecords.Count)</a>
    <a class="tab @(tab == "fail"  ? "active" : "")" href="?tab=fail">Failures (@m.FailureRecords.Count)</a>
  </div>

  <!-- OVERVIEW -->
  @if (tab == "info")
  {
    <div class="stat-row">
      <div class="stat"><div class="stat-bar"></div><div class="val">@m.MaintenanceRecords.Count</div><div class="lbl">Maintenance Logs</div></div>
      <div class="stat"><div class="stat-bar"></div><div class="val">@m.FailureRecords.Count</div><div class="lbl">Failure Logs</div></div>
      <div class="stat"><div class="stat-bar"></div><div class="val">@m.Period.Split(' ')[0]</div><div class="lbl">Interval</div></div>
      <div class="stat"><div class="stat-bar"></div><div class="val">@m.Energy</div><div class="lbl">Energy</div></div>
    </div>

    <div class="section-label">Identification</div>
    <div class="info-grid">
      <div class="info-field"><div class="if-label">Machine Code</div><div class="if-val">@(m.Code ?? "—")</div></div>
      <div class="info-field"><div class="if-label">Machine Name</div><div class="if-val">@m.Name</div></div>
      <div class="info-field"><div class="if-label">Brand / Manufacturer</div><div class="if-val">@(m.Brand ?? "—")</div></div>
      <div class="info-field"><div class="if-label">Maintenance Period</div><div class="if-val">@m.Period</div></div>
      <div class="info-field"><div class="if-label">Plan Date</div><div class="if-val">@(m.PlanDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
      <div class="info-field"><div class="if-label">Card Date</div><div class="if-val">@(m.CardDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
    </div>

    <div class="section-label">Technical Specifications</div>
    <div class="info-grid">
      <div class="info-field"><div class="if-label">Energy Source</div><div class="if-val">@m.Energy</div></div>
      <div class="info-field"><div class="if-label">Working Voltage</div><div class="if-val">@(m.Voltage ?? "—")</div></div>
      <div class="info-field"><div class="if-label">Working Pressure</div><div class="if-val">@(m.Pressure ?? "—")</div></div>
      <div class="info-field"><div class="if-label">Total Power</div><div class="if-val">@(m.Power ?? "—")</div></div>
      <div class="info-field"><div class="if-label">Primary Usage</div><div class="if-val">@(m.Usage ?? "—")</div></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(m.Specs) || !string.IsNullOrWhiteSpace(m.Notes))
    {
      <div class="section-label">Description</div>
      <div class="info-grid">
        @if (!string.IsNullOrWhiteSpace(m.Specs))
        {
          <div class="info-field full"><div class="if-label">Specifications</div><div class="if-val">@m.Specs</div></div>
        }
        @if (!string.IsNullOrWhiteSpace(m.Notes))
        {
          <div class="info-field full"><div class="if-label">Additional Notes</div><div class="if-val">@m.Notes</div></div>
        }
      </div>
    }
  }

  <!-- MAINTENANCE -->
  @if (tab == "maint")
  {
    <div class="tab-action-row">
      <a class="btn primary" href="/Machines/@m.Id/Maintenance/Create">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Record
      </a>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th><th>Performed By</th><th>Work Done / Parts Replaced</th><th>Result</th><th></th>
          </tr>
        </thead>
        <tbody>
          @if (!m.MaintenanceRecords.Any())
          {
            <tr><td colspan="5" class="empty-row">No maintenance records yet.</td></tr>
          }
          @foreach (var r in m.MaintenanceRecords.OrderByDescending(x => x.Id))
          {
            <tr>
              <td>@(r.Date ?? "—")</td>
              <td>@(r.PerformedBy ?? "—")</td>
              <td>@(r.WorkDone ?? "—")</td>
              <td><span class="tag @(r.Result == "OK" ? "ok" : "warn")">@r.Result</span></td>
              <td>
                <div class="row-actions">
                  <a class="btn sm" href="/Machines/@m.Id/Maintenance/Edit/@r.Id">Edit</a>
                  <form method="post" asp-page-handler="DeleteMaintenance">
                    <input type="hidden" name="recordId" value="@r.Id" />
                    <button type="submit" class="btn sm danger" onclick="return confirm('Delete this record?')">Del</button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- FAILURES -->
  @if (tab == "fail")
  {
    <div class="tab-action-row">
      <a class="btn primary" href="/Machines/@m.Id/Failures/Create">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Record
      </a>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th><th>Fault Description</th><th>Type</th>
            <th>Action 1</th><th>Action 2</th><th>Assigned To</th><th>Result</th><th></th>
          </tr>
        </thead>
        <tbody>
          @if (!m.FailureRecords.Any())
          {
            <tr><td colspan="8" class="empty-row">No failure records yet.</td></tr>
          }
          @foreach (var r in m.FailureRecords.OrderByDescending(x => x.Id))
          {
            <tr>
              <td>@(r.Date ?? "—")</td>
              <td>@(r.Description ?? "—")</td>
              <td>@(r.FaultType ?? "—")</td>
              <td>@(r.Action1 ?? "—")</td>
              <td>@(r.Action2 ?? "—")</td>
              <td>@(r.AssignedTo ?? "—")</td>
              <td><span class="tag @(r.Result == "OK" ? "ok" : "warn")">@r.Result</span></td>
              <td>
                <div class="row-actions">
                  <a class="btn sm" href="/Machines/@m.Id/Failures/Edit/@r.Id">Edit</a>
                  <form method="post" asp-page-handler="DeleteFailure">
                    <input type="hidden" name="recordId" value="@r.Id" />
                    <button type="submit" class="btn sm danger" onclick="return confirm('Delete this record?')">Del</button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
